# server/.env

# Flask settings
FLASK_APP=app.py
FLASK_ENV=development

# PostgreSQL database URL
# Replace 'username', 'password', and 'ecommerce_db' with your actual DB credentials
DATABASE_URL=postgresql://faithkerubo:password@localhost:5432/ecommerce_db

# JWT secret key (used for user authentication)
JWT_SECRET_KEY=your_jwt_secret_key

# Stripe keys (for payments)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key